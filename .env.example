# ============================================================================
# Task Management Platform - Microservices Configuration
# ============================================================================
# Copy this file to .env.local and update with your values
# This file is used by docker-compose.yml for all microservices
# ============================================================================

# ============================================================================
# DOCKER & REGISTRY CONFIGURATION
# ============================================================================
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your-dockerhub-username
DOCKER_PASSWORD=your-dockerhub-password-or-token

# ============================================================================
# DATABASE CONFIGURATION (Shared across all services)
# ============================================================================
SPRING_DATASOURCE_USERNAME=taskuser
SPRING_DATASOURCE_PASSWORD=taskpassword

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Generate a new JWT secret with:
# openssl rand -base64 32
# or
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=ZGV2LW9ubHktcGxhY2Vib2xkZXIta2V5LWNoYW5nZS1tZS1pbi1wcm9kdWN0aW9uIQ==

# Token expiration in milliseconds (86400000 = 24 hours)
JWT_EXPIRATION=86400000

# ============================================================================
# AUTH SERVICE CONFIGURATION
# ============================================================================
AUTH_SERVICE_PORT=8081
AUTH_DB_PASSWORD=${SPRING_DATASOURCE_PASSWORD}
AUTH_DB_USER=${SPRING_DATASOURCE_USERNAME}

# Default admin account (created on first startup)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@taskmanager.com
ADMIN_PASSWORD=admin123

# ============================================================================
# TASK SERVICE CONFIGURATION
# ============================================================================
TASK_SERVICE_PORT=8082
TASK_DB_PASSWORD=${SPRING_DATASOURCE_PASSWORD}
TASK_DB_USER=${SPRING_DATASOURCE_USERNAME}

# ============================================================================
# USER SERVICE CONFIGURATION
# ============================================================================
USER_SERVICE_PORT=8083
USER_DB_PASSWORD=${SPRING_DATASOURCE_PASSWORD}
USER_DB_USER=${SPRING_DATASOURCE_USERNAME}

# ============================================================================
# API GATEWAY CONFIGURATION
# ============================================================================
API_GATEWAY_PORT=8080

# Service discovery URL (Eureka)
EUREKA_URL=http://service-discovery:8761/eureka/
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=${EUREKA_URL}

# ============================================================================
# SERVICE DISCOVERY (EUREKA) CONFIGURATION
# ============================================================================
EUREKA_PORT=8761
EUREKA_INSTANCE_HOSTNAME=localhost

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# ============================================================================
# DATABASE CONFIGURATION (Individual Services)
# ============================================================================

# Auth Service Database
AUTH_DATASOURCE_URL=jdbc:postgresql://auth-db:5432/auth_db
AUTH_DATASOURCE_USERNAME=${SPRING_DATASOURCE_USERNAME}
AUTH_DATASOURCE_PASSWORD=${SPRING_DATASOURCE_PASSWORD}

# Task Service Database
TASK_DATASOURCE_URL=jdbc:postgresql://task-db:5432/task_db
TASK_DATASOURCE_USERNAME=${SPRING_DATASOURCE_USERNAME}
TASK_DATASOURCE_PASSWORD=${SPRING_DATASOURCE_PASSWORD}

# User Service Database
USER_DATASOURCE_URL=jdbc:postgresql://user-db:5432/user_db
USER_DATASOURCE_USERNAME=${SPRING_DATASOURCE_USERNAME}
USER_DATASOURCE_PASSWORD=${SPRING_DATASOURCE_PASSWORD}

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Spring Boot Logging Level
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_TASKMANAGER=DEBUG

# Actuator exposure
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus

# ============================================================================
# HIBERNATE / JPA CONFIGURATION
# ============================================================================

# DDL Strategy: validate, update, create, create-drop
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Show SQL statements (disable in production)
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=false

# ============================================================================
# KUBERNETES / CLOUD DEPLOYMENT
# ============================================================================

# Image Registry for K8s deployments
K8S_IMAGE_REGISTRY=docker.io
K8S_IMAGE_PULL_POLICY=IfNotPresent

# Namespace for K8s
K8S_NAMESPACE=task-management

# ============================================================================
# ENVIRONMENT PROFILES
# ============================================================================

# Spring profiles: local, dev, staging, prod
SPRING_PROFILES_ACTIVE=local

# ============================================================================
# OPTIONAL: ADVANCED CONFIGURATION
# ============================================================================

# Connection Pool Settings
DB_POOL_MAX_SIZE=20
DB_POOL_MIN_IDLE=5
DB_CONNECTION_TIMEOUT=20000

# JVM Settings
JAVA_OPTS=-Xms512m -Xmx1g -XX:+UseG1GC

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_MAX_AGE=3600

# ============================================================================
# NOTES FOR PRODUCTION DEPLOYMENT
# ============================================================================

# 1. Change all default passwords
# 2. Use strong JWT_SECRET (32+ bytes, random)
# 3. Set SPRING_DATASOURCE_PASSWORD to a strong, unique password
# 4. Update ADMIN_PASSWORD to a strong value
# 5. Set SPRING_PROFILES_ACTIVE=prod for production
# 6. Update NEXT_PUBLIC_API_URL to your production domain
# 7. Enable HTTPS/TLS for all services
# 8. Use a secrets manager (HashiCorp Vault, AWS Secrets Manager)
# 9. Enable logging aggregation (ELK, Splunk, CloudWatch)
# 10. Set up monitoring and alerting (Prometheus, Grafana)
